# Generated by Ansible — do not edit manually
# {{ ansible_managed }}

anthropic:
  api_key: ""   # injected via ANTHROPIC_API_KEY env var
  model: "claude-sonnet-4-20250514"
  batch_size: 40

snipeit:
  enabled: true
  base_url: "{{ cmdb_agent_snipeit_url }}"
  api_token: ""   # injected via SNIPEIT_TOKEN env var
  default_category_id: {{ cmdb_agent_snipeit_category_id | default(1) }}
  default_status_id: {{ cmdb_agent_snipeit_status_id | default(1) }}

glpi:
  enabled: true
  base_url: "{{ cmdb_agent_glpi_url }}"
  app_token: ""   # injected via GLPI_APP_TOKEN env var
  user_token: ""  # injected via GLPI_USER_TOKEN env var

scan:
  scan_python: true
  scan_npm: true
  scan_java: true
  npm_search_roots: {{ cmdb_agent_npm_roots | default(['/opt', '/srv', '/var/www', '/app']) | to_yaml }}
  java_search_roots: {{ cmdb_agent_java_roots | default(['/opt', '/srv', '/var', '/app', '/usr/share/java']) | to_yaml }}

output:
  save_raw_snapshot: {{ cmdb_agent_save_snapshot | default(false) | lower }}
  raw_snapshot_path: "/var/log/cmdb-agent/snapshot.json"

logging:
  level: "{{ cmdb_agent_log_level | default('INFO') }}"
  log_file: "/var/log/cmdb-agent/agent.log"
